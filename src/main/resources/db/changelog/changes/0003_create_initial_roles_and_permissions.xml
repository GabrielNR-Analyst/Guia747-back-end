    <changeSet id="1" author="Guilherme Oliveira">
        <!-- create default roles -->
        <insert tableName="roles">
            <column name="id" value="7f53afb3-133e-425f-ac52-a226f44a66d7"/>
            <column name="name" value="ADMINISTRATOR"/>
            <column name="description"
                    value="Tem controle total sobre o sistema, incluindo gerenciamento de usuários, empresas, locais, conteúdo e configurações RBAC."/>
        </insert>
        <insert tableName="roles">
            <column name="id" value="3bd1f86d-4db6-4353-b0e8-ca0626dbbcff"/>
            <column name="name" value="COMPANY_REPRESENTATIVE"/>
            <column name="description"
                    value="Usuário que representa uma empresa; responsável por gerenciar o perfil da empresa e os locais a ela associados."/>
        </insert>
        <insert tableName="roles">
            <column name="id" value="3f4aa4ef-2571-4407-8e28-8c21fdac2db6"/>
            <column name="name" value="USER"/>
            <column name="description" value="Usuário comum que pode visualizar locais, cidades e enviar avaliações."/>
        </insert>
    </changeSet>

